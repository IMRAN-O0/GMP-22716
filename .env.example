# ===== إعدادات الأمان =====

# مفتاح JWT — مطلوب في الإنتاج (غيّره لسلسلة عشوائية لا تقل عن 48 حرفاً)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ===== إعدادات السيرفر =====
PORT=3000
NODE_ENV=production

# العناوين المسموح بها للاتصال (افصل بفاصلة إذا أكثر من عنوان)
# للتشغيل على LAN: غيّر إلى IP جهازك مثل: http://192.168.1.10:3000
ALLOWED_ORIGINS=http://localhost:3000

# ===== مسار قاعدة البيانات (اختياري) =====
# الافتراضي: QForm_Data.db في مجلد المشروع
# DB_PATH=/path/to/your/QForm_Data.db

# ===== إعدادات البريد الإلكتروني (اختياري) =====
SMTP_HOST=smtp.your-server.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password
