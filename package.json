{
  "name": "gmp-qms",
  "productName": "نظام GMP لإدارة الجودة",
  "private": true,
  "version": "1.0.0",
  "description": "نظام إدارة الجودة GMP للصناعات الدوائية والتجميلية",
  "author": "Modern Cosmetics Co.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production node server-bundle.cjs",
    "build": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "build:all": "npm run build && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist server-bundle.cjs",
    "lint": "tsc --noEmit",
    "electron:dev": "npm run build:server && electron .",
    "electron:build": "npm run build:all && electron-builder --win --publish never",
    "electron:build:linux": "npm run build:all && electron-builder --linux --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express-rate-limit": "^5.1.3",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.moderncosmetics.gmp",
    "productName": "نظام GMP",
    "copyright": "Modern Cosmetics Co.",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "node_modules/sqlite3/**/*",
      "node_modules/bcryptjs/**/*"
    ],
    "extraResources": [
      {
        "from": "server-bundle.cjs",
        "to": "server-bundle.cjs"
      },
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "node_modules/sqlite3",
        "to": "node_modules/sqlite3"
      }
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "zip",      "arch": ["x64"] }
      ],
      "icon": "electron/icon.png",
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateSubjectName": null,
      "certificateSha1": null
    },
    "portable": {
      "artifactName": "نظام-GMP-${version}-portable.exe"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/icon.png",
      "category": "Office"
    },
    "asar": true
  }
}
